# Vercel Production Deployment Required Environment Variables
# Copy to .env.local and fill with real values
# NEVER commit real secrets!

DATABASE_URL="postgresql://username:password@host:port/database?schema=public"
NEXTAUTH_SECRET="your-nextauth-secret-key-generated-with-openssl-rand -base64 32"
OPENAI_API_KEY="sk-your-openai-api-key"

# Optional for Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Lucia Auth (if used)
LUCIA_SECRET="your-lucia-secret"

